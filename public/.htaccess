<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Si le fichier/dossier existe physiquement, le servir tel quel
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Sinon, fallback vers index.html (le shell SPA)
  RewriteRule ^ index.html [L]
</IfModule>

# Mise en cache agressive des assets versionnés (hash dans le nom)
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2|woff|ttf|otf|jpg|jpeg|png|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Pas de cache sur index.html pour que les updates passent
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>